{
  "entities": {
    "TournamentData": {
      "title": "Tournament Data",
      "description": "Global state for the tournament including current match and bracket matches",
      "type": "object",
      "properties": {
        "currentMatch": {
          "type": "object",
          "properties": {
            "p1": { "type": "string" },
            "p2": { "type": "string" },
            "score": { "type": "string" }
          },
          "required": ["p1", "p2", "score"]
        },
        "matches": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "t1": { "type": "string" },
              "t2": { "type": "string" },
              "s1": { "type": "string" },
              "s2": { "type": "string" }
            },
            "required": ["id", "t1", "t2", "s1", "s2"]
          }
        }
      },
      "required": ["currentMatch", "matches"]
    }
  },
  "firestore": {
    "/tournament/data": {
      "schema": { "$ref": "TournamentData" },
      "description": "The single source of truth for the tournament"
    }
  }
}
